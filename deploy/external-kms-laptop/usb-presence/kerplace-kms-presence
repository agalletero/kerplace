#!/usr/bin/env bash
# kerplace-kms-presence — backstop de la regla udev. Sondea la presencia del USB de
# custodia (por UUID de filesystem) y, si desaparece estando el KMS des-sellado,
# dispara la acción de sellado. Garantiza el sellado aunque se pierda el evento udev
# (suspend/resume, replug rápido). udev da el sellado INSTANTÁNEO; esto es la red.
#
# 1 USB <-> 1 KMS: va keyado al UUID de UN USB. Para varias instancias KMS, una
# unidad de estas por instancia, cada una con su UUID.
[ -r /etc/kerplace/custody.env ] && . /etc/kerplace/custody.env
UUID="${KP_CUSTODY_USB_UUID:?define KP_CUSTODY_USB_UUID en /etc/kerplace/custody.env}"
ADDR="${KP_KMS_ADDR:-https://127.0.0.1:8200}"
CACERT="${KP_KMS_CACERT:-/etc/openbao/tls/ca.crt}"
POLL="${KP_CUSTODY_POLL:-2}"
BAO=/usr/bin/bao; PY=/usr/bin/python3; SC=/usr/bin/systemctl

sealed(){ VAULT_ADDR="$ADDR" VAULT_CACERT="$CACERT" "$BAO" status -format=json 2>/dev/null \
  | "$PY" -c 'import sys,json;print(json.load(sys.stdin).get("sealed"))' 2>/dev/null; }

while :; do
  if [ ! -e "/dev/disk/by-uuid/$UUID" ] && [ "$(sealed)" = "False" ]; then
    logger -t kerplace-kms-presence "USB $UUID ausente -> seal"
    "$SC" start kerplace-kms-seal.service
  fi
  sleep "$POLL"
done
