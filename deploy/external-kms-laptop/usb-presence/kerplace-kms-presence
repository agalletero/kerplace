#!/usr/bin/env bash
# kerplace-kms-presence — backstop for the udev rule. Polls for the custody USB
# (by filesystem UUID) and, if it disappears while the KMS is unsealed, triggers
# the sealing action. This guarantees sealing even when the udev event is lost
# (suspend/resume, a fast replug). udev gives INSTANT sealing; this is the net.
#
# 1 USB <-> 1 KMS: this is keyed to ONE USB's UUID. For several KMS instances,
# run one of these units per instance, each with its own UUID.
[ -r /etc/kerplace/custody.env ] && . /etc/kerplace/custody.env
UUID="${KP_CUSTODY_USB_UUID:?set KP_CUSTODY_USB_UUID in /etc/kerplace/custody.env}"
ADDR="${KP_KMS_ADDR:-https://127.0.0.1:8200}"
CACERT="${KP_KMS_CACERT:-/etc/openbao/tls/ca.crt}"
POLL="${KP_CUSTODY_POLL:-2}"
BAO=/usr/bin/bao; PY=/usr/bin/python3; SC=/usr/bin/systemctl

sealed(){ VAULT_ADDR="$ADDR" VAULT_CACERT="$CACERT" "$BAO" status -format=json 2>/dev/null \
  | "$PY" -c 'import sys,json;print(json.load(sys.stdin).get("sealed"))' 2>/dev/null; }

while :; do
  if [ ! -e "/dev/disk/by-uuid/$UUID" ] && [ "$(sealed)" = "False" ]; then
    logger -t kerplace-kms-presence "USB $UUID absent -> seal"
    "$SC" start kerplace-kms-seal.service
  fi
  sleep "$POLL"
done
