#!/usr/bin/env bash
# kerplace-kms-seal — the custody sealing action. Idempotent.
# Lazy-unmounts every KerPlace s3fs mount and seals the KMS (OpenBao). Invoked by
# both the udev rule (on USB REMOVAL) and the presence monitor (as a backstop).
# The lazy unmount stops a broken mount from hanging `df -h` / `ls` until a timeout.
[ -r /etc/kerplace/custody.env ] && . /etc/kerplace/custody.env
SVC="${KP_KMS_SERVICE:-openbao}"

while read -r _ mp fstype _; do
  [ "$fstype" = "fuse.s3fs" ] || continue
  logger -t kerplace-kms-seal "lazy-umount $mp"
  umount -l "$mp" 2>/dev/null || fusermount3 -uz "$mp" 2>/dev/null || true
done < /proc/mounts

/usr/bin/systemctl restart "$SVC"
