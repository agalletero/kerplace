# adminkp.env — configuration for adminKP.sh (off-host KMS custody).
#
# Copy it to:  ${XDG_CONFIG_HOME:-$HOME/.config}/kerplace/adminkp.env
# and protect it: chmod 600. Every variable is KP_ADMIN_*. The first five are
# REQUIRED; the rest have sensible defaults.

# ── Required ─────────────────────────────────────────────────────────────────
KP_ADMIN_HOST="user@your-host"                  # SSH destination of the KerPlace host
KP_ADMIN_SSH_KEY="<PATH>/.ssh/kerplace.key"     # SSH private key for that host
KP_ADMIN_ACCESS_KEY="kp-mounter"                # SCOPED S3 user for mounting, not root
KP_ADMIN_SECRET_FILE="<PATH>/.config/kerplace/s3.secret"  # file holding that user's secret (chmod 600)
KP_ADMIN_KMS_DIR="<PATH>/kerplace-kms"          # reference dir: compose + start.sh + vault/

# ── Optional (with defaults) ─────────────────────────────────────────────────
# S3 endpoint: loopback via the SSH tunnel's -L forward. Encryption in transit is
# provided by the SSH channel (ML-KEM); the host's public 9000 port can stay shut.
KP_ADMIN_S3_ENDPOINT="http://127.0.0.1:9000"

KP_ADMIN_MOUNT_BASE="$HOME/buckets"             # where buckets appear as folders
KP_ADMIN_TUNNEL_UNIT="kerplace-kms-tunnel.service"   # systemd --user unit of the tunnel

# Custody USB holding the unseal material
KP_ADMIN_USB_LABEL="KPCUSTODY"                  # filesystem LABEL of the USB
KP_ADMIN_USB_FILE="kerplace-custody/unseal.json.gpg"  # path relative to the USB root

# SSH channel pinning. DEDICATED known_hosts (no TOFU); populate at provisioning:
#   ssh-keyscan -t ed25519 <HOST> >> <this_file>   # and verify the fingerprint
KP_ADMIN_KNOWN_HOSTS="$HOME/.config/kerplace/known_hosts"
# The post-quantum KEX is pinned by policy. You may allow a second one:
#   KP_ADMIN_KEX="mlkem768x25519-sha256,sntrup761x25519-sha512"
KP_ADMIN_KEX="mlkem768x25519-sha256"

# Vault infrastructure (rarely changed)
KP_ADMIN_VAULT_CONTAINER="kerplace-vault"
KP_ADMIN_VAULT_VOLUME="kerplace-kms_vault-data"
KP_ADMIN_PASSWD_S3FS="$HOME/.passwd-s3fs-adminkp"

# ── Automation escapes (optional, NOT recommended interactively) ──────────────
# Passphrases via variables instead of pinentry. They are exposed in
# /proc/<pid>/environ.
#   ADMINKP_PASSPHRASE=...          # USB unseal / the backup's data artifact
#   ADMINKP_UNSEAL_PASSPHRASE=...   # the backup's unseal artifact
# KP_ADMIN_DEBUG=1                  # enable [DEBUG] traces
