# adminkp.env — configuración de adminKP.sh (custodia KMS off-host).
#
# Cópialo a:  ${XDG_CONFIG_HOME:-$HOME/.config}/kerplace/adminkp.env
# y protégelo: chmod 600. Todas las variables son KP_ADMIN_*. Las 5 primeras son
# OBLIGATORIAS; el resto tiene valores por defecto sensatos.

# ── Obligatorias ─────────────────────────────────────────────────────────────
KP_ADMIN_HOST="user@your-host"                 # destino SSH del host de KerPlace
KP_ADMIN_SSH_KEY="<PATH>/.ssh/kerplace.key"     # clave privada SSH para ese host
KP_ADMIN_ACCESS_KEY="kp-mounter"                # usuario S3 SCOPED para montar (T3), no el root
KP_ADMIN_SECRET_FILE="<PATH>/.config/kerplace/s3.secret"  # fichero con el secret de ese usuario (chmod 600)
KP_ADMIN_KMS_DIR="<PATH>/kerplace-kms"          # dir de referencia: compose + start.sh + vault/

# ── Opcionales (con default) ─────────────────────────────────────────────────
# Endpoint S3: loopback vía el −L del túnel SSH (T1). El cifrado en tránsito lo
# aporta el canal SSH (ML-KEM); el puerto 9000 público del host puede cerrarse.
KP_ADMIN_S3_ENDPOINT="http://127.0.0.1:9000"

KP_ADMIN_MOUNT_BASE="$HOME/buckets"             # donde aparecen los buckets como carpetas
KP_ADMIN_TUNNEL_UNIT="kerplace-kms-tunnel.service"   # unidad systemd --user del túnel

# USB de custodia del material de unseal (T2)
KP_ADMIN_USB_LABEL="KPCUSTODY"                  # LABEL del filesystem del USB
KP_ADMIN_USB_FILE="kerplace-custody/unseal.json.gpg"  # ruta relativa dentro del USB

# Pin de canal SSH (T4). known_hosts DEDICADO (sin TOFU); poblar en aprovisionamiento:
#   ssh-keyscan -t ed25519 <HOST> >> <este_fichero>   # y verifica el fingerprint
KP_ADMIN_KNOWN_HOSTS="$HOME/.config/kerplace/known_hosts"
# KEX post-cuántico fijado por política. Puedes añadir un segundo permitido:
#   KP_ADMIN_KEX="mlkem768x25519-sha256,sntrup761x25519-sha512"
KP_ADMIN_KEX="mlkem768x25519-sha256"

# Infra Vault (raramente se cambian)
KP_ADMIN_VAULT_CONTAINER="kerplace-vault"
KP_ADMIN_VAULT_VOLUME="kerplace-kms_vault-data"
KP_ADMIN_PASSWD_S3FS="$HOME/.passwd-s3fs-adminkp"

# ── Escapes de automatización (opcionales, NO recomendados de forma interactiva) ─
# Passphrases por variable en vez de pinentry. Quedan expuestas en /proc/<pid>/environ.
#   ADMINKP_PASSPHRASE=...          # unseal USB / artefacto de datos del backup
#   ADMINKP_UNSEAL_PASSPHRASE=...   # artefacto de unseal del backup (T7)
# KP_ADMIN_DEBUG=1                  # activa trazas [DEBUG]
