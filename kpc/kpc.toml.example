# kpc — custody client configuration. Copy it to:
#   /etc/kerplace/kpc.toml   (system-wide)   or   ~/.config/kerplace/kpc.toml
# Use ABSOLUTE paths (no ~).

[kms]
addr    = "https://127.0.0.1:8200"           # KMS (OpenBao) endpoint, reached over the tunnel
cacert  = "/etc/openbao/tls/ca.crt"          # the KMS's private CA (must be readable by whoever runs kpc)
service = "openbao"                          # systemd service to restart on 'kpc seal'

[usb]
label       = "Ventoy"                       # filesystem LABEL of the custody USB
uuid        = "3431-7DD1"                    # filesystem UUID (the authoritative presence signal)
unseal_file = "kerplace-custody/unseal.json.gpg"   # path to the material inside the USB

# One or more KerPlace instances/hosts (a single KMS can serve several).
[[instances]]
name        = "gcp"
tunnel_unit = "kerplace-gcp-tunnel.service"  # systemd --user unit of the tunnel
s3_endpoint = "http://127.0.0.1:9000"        # S3 endpoint (loopback, via the tunnel)
access_key  = "kpadmin"
secret_file = "/etc/kerplace/gcp-s3.secret"  # file holding the secret (chmod 600)
buckets     = [ { name = "obsidian", mountpoint = "/home/USER/kerplace/obsidian" } ]
